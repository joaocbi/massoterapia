PORT=3000
ADMIN_PASSWORD=change-this-to-a-strong-password
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
# Required on Vercel (serverless): SQLite in /tmp does not persist. Use Neon, Supabase, or Vercel Postgres.
DATABASE_URL=
# Optional: some Vercel integrations set POSTGRES_URL instead (server.js copies it to DATABASE_URL).
POSTGRES_URL=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
