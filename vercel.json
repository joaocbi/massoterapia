{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "site-config.js", "use": "@vercel/static" },
    { "src": "logo-flow.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/site-config.js", "dest": "/site-config.js" },
    { "src": "/logo-flow.png", "dest": "/logo-flow.png" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
