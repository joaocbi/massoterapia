{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "site-config.js", "use": "@vercel/static" },
    { "src": "img/logo-flow.png", "use": "@vercel/static" },
    { "src": "img/flowclass.png", "use": "@vercel/static" },
    { "src": "img/service-relaxante.png", "use": "@vercel/static" },
    { "src": "img/service-terapeutica.png", "use": "@vercel/static" },
    { "src": "img/service-ritual.png", "use": "@vercel/static" },
    { "src": "admin/index.html", "use": "@vercel/static" },
    { "src": "fisiosaude/index.html", "use": "@vercel/static" },
    { "src": "fisiosaude/admin/index.html", "use": "@vercel/static" },
    { "src": "fisiosaude/brand.css", "use": "@vercel/static" },
    { "src": "fisiosaude/site-config.js", "use": "@vercel/static" },
    { "src": "fisiosaude/img/logo-fisiosaude.png", "use": "@vercel/static" },
    { "src": "fisiosaude/img/fisio-panel-hero.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/fisiosaude/brand.css", "dest": "/fisiosaude/brand.css" },
    { "src": "/fisiosaude/site-config.js", "dest": "/fisiosaude/site-config.js" },
    { "src": "/fisiosaude/img/(.*)", "dest": "/fisiosaude/img/$1" },
    { "src": "/fisiosaude/admin/?", "dest": "/fisiosaude/admin/index.html" },
    { "src": "/fisiosaude/", "dest": "/fisiosaude/index.html" },
    { "src": "/fisiosaude", "dest": "/fisiosaude/index.html" },
    { "src": "/admin/?", "dest": "/admin/index.html" },
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/site-config.js", "dest": "/site-config.js" },
    { "src": "/img/logo-flow.png", "dest": "/img/logo-flow.png" },
    { "src": "/img/flowclass.png", "dest": "/img/flowclass.png" },
    { "src": "/img/service-relaxante.png", "dest": "/img/service-relaxante.png" },
    { "src": "/img/service-terapeutica.png", "dest": "/img/service-terapeutica.png" },
    { "src": "/img/service-ritual.png", "dest": "/img/service-ritual.png" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
